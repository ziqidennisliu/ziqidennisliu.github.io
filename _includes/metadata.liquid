{% if site.enable_google_verification or site.enable_bing_verification %}
  <!-- Website verification -->
  {% if site.enable_google_verification %}
    <meta name="google-site-verification" content="{{ site.google_site_verification }}">
  {% endif %}
  {% if site.enable_bing_verification %}
    <meta name="msvalidate.01" content="{{ site.bing_site_verification }}">
  {% endif %}
  <meta http-equiv="Permissions-Policy" content="interest-cohort=()">
{% endif %}

{% capture author_name %}{{ site.first_name }}{% if site.middle_name %} {{ site.middle_name }}{% endif %} {{ site.last_name }}{% endcapture %}
{% assign author_name = author_name | strip %}
{% if site.title == 'blank' %}
  {% assign site_name = author_name %}
{% else %}
  {% assign site_name = site.title %}
{% endif %}
{% assign seo_description = site.seo_descriptions[page.url] %}
{% if seo_description %}
  {% assign page_description = seo_description %}
{% elsif page.description %}
  {% assign page_description = page.description %}
{% else %}
  {% assign page_description = site.description %}
{% endif %}
{% assign canonical_url = page.url | replace: 'index.html', '' | absolute_url %}
{% if page.url == '/blog/index.html' %}
  {% capture seo_title %}{{ page.title }} | {{ site_name }}{% endcapture %}
{% elsif page.title != 'blank' and page.url != '/' %}
  {% if page.title == null or page.title == '' %}
    {% capture seo_title %}{{ page.date | date: '%Y' }} | {{ site_name }}{% endcapture %}
  {% else %}
    {% capture seo_title %}{{ page.title }} | {{ site_name }}{% endcapture %}
  {% endif %}
{% else %}
  {% assign seo_title = site_name %}
{% endif %}

<!-- Standard metadata -->
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>{{ seo_title | strip }}</title>
<meta name="author" content="{{ author_name }}">
<meta name="description" content="{{ page_description | strip_html | strip }}">
{% if page.keywords or site.keywords %}
  <meta name="keywords" content="{% if page.keywords %}{{ page.keywords }}{% else %}{{ site.keywords }}{% endif %}">
{% endif %}

{% assign is_blog_post = false %}
{% if page.url != '/blog/index.html' and page.url contains '/blog/' %}
  {% unless page.url contains '/tag/' or page.url contains '/category/' %}
    {% assign is_blog_post = true %}
  {% endunless %}
{% endif %}

{% if site.serve_og_meta %}
  {% if page.og_image %}
    {% assign social_image = page.og_image | absolute_url %}
  {% elsif site.og_image %}
    {% assign social_image = site.og_image | absolute_url %}
  {% endif %}
  <!-- OpenGraph -->
  <meta property="og:site_name" content="{{ site_name }}">
  <meta property="og:type" content="{% if is_blog_post %}article{% else %}website{% endif %}">
  <meta property="og:title" content="{{ seo_title | strip }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:description" content="{{ page_description | strip_html | strip }}">
  {% if social_image %}
    <meta property="og:image" content="{{ social_image }}">
  {% endif %}
  <meta property="og:locale" content="{{ site.lang }}">

  <!-- Twitter card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ seo_title | strip }}">
  <meta name="twitter:description" content="{{ page_description | strip_html | strip }}">
  {% if social_image %}
    <meta name="twitter:image" content="{{ social_image }}">
  {% endif %}
{% endif %}

{% if site.serve_schema_org %}
  <!-- Schema.org -->
  <script type="application/ld+json">
    {% if page.url == '/' %}
      {
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        "@id": {{ canonical_url | append: '#profile-page' | jsonify }},
        "url": {{ canonical_url | jsonify }},
        "name": {{ seo_title | strip | jsonify }},
        "description": {{ page_description | strip_html | strip | jsonify }},
        "mainEntity": {
          "@type": "Person",
          "@id": {{ site.url | append: '/#person' | jsonify }},
          "name": {{ site.first_name | jsonify }},
          "alternateName": {{ site.last_name | jsonify }},
          "url": {{ site.url | append: '/' | jsonify }},
          "image": {{ '/assets/img/mypic.jpg' | absolute_url | jsonify }},
          "jobTitle": "MPhil Student and HCI Researcher",
          "affiliation": {
            "@type": "CollegeOrUniversity",
            "name": "Hong Kong University of Science and Technology",
            "alternateName": "HKUST",
            "url": "https://hkust.edu.hk/"
          },
          "memberOf": {
            "@type": "ResearchOrganization",
            "name": "UbiquitousX Lab",
            "url": "https://qijiashao.github.io/team/"
          },
          "alumniOf": {
            "@type": "CollegeOrUniversity",
            "name": "Tsinghua University",
            "alternateName": "THU",
            "url": "https://www.tsinghua.edu.cn/en/"
          },
          "knowsAbout": [
            "Human-Computer Interaction",
            "HCI",
            "Mobile Computing",
            "Ubiquitous Computing",
            "Mobile and Wearable Sensing",
            "Adaptive Interaction",
            "Mobile Health"
          ],
          "sameAs": [
            "https://scholar.google.com/citations?user={{ site.scholar_userid }}",
            "https://orcid.org/{{ site.orcid_id }}",
            "https://github.com/{{ site.github_username }}",
            "https://www.linkedin.com/in/{{ site.linkedin_username }}"
          ]
        }
      }
    {% else %}
      {
        "@context": "https://schema.org",
        "@type": "{% if is_blog_post %}BlogPosting{% else %}WebPage{% endif %}",
        "@id": {{ canonical_url | append: '#webpage' | jsonify }},
        "url": {{ canonical_url | jsonify }},
        "name": {{ seo_title | strip | jsonify }},
        "headline": {{ page.title | default: seo_title | strip | jsonify }},
        "description": {{ page_description | strip_html | strip | jsonify }},
        "author": {
          "@type": "Person",
          "@id": {{ site.url | append: '/#person' | jsonify }},
          "name": {{ site.first_name | jsonify }},
          "url": {{ site.url | append: '/' | jsonify }}
        }
      }
    {% endif %}
  </script>
{% endif %}
